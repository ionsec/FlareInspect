{
  "name": "flareinspect",
  "version": "1.1.0",
  "description": "FlareInspect - Cloudflare Security Assessment CLI Tool by IONSEC.IO",
  "main": "src/cli/index.js",
  "bin": {
    "flareinspect": "./src/cli/index.js"
  },
  "scripts": {
    "start": "node src/cli/index.js",
    "web": "node web/server.js",
    "dev": "nodemon web/server.js",
    "interactive": "node src/cli/interactive.js",
    "test": "jest",
    "lint": "eslint src tests web *.js",
    "docker:build": "docker build -t flareinspect .",
    "docker:run": "docker run -it --rm flareinspect"
  },
  "keywords": [
    "cloudflare",
    "security",
    "assessment",
    "cli",
    "ocsf",
    "ionsec"
  ],
  "author": "IONSEC.IO",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ionsec/flareinspect"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "cloudflare": "^4.5.0",
    "commander": "^11.1.0",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "figlet": "^1.7.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ora": "^5.4.1",
    "p-limit": "^7.3.0",
    "progress": "^2.0.3",
    "uuid": "^10.0.0",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "eslint": "^9.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "commonjs",
  "overrides": {
    "flatted": "^3.4.2",
    "minimatch": "^3.1.5",
    "lodash": "^4.18.1",
    "ajv": "^6.14.0",
    "picomatch": "^2.3.2",
    "qs": "^6.14.2"
  }
}
